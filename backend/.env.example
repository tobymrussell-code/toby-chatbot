# Copy this file to .env and fill in real values.

# Required: your Anthropic API key (used for room detection + report generation)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: model override
ANTHROPIC_MODEL=claude-sonnet-4-6

# Port the API server listens on
PORT=3000

# Public base URL the mobile app can reach this server at.
# For a physical phone on the same Wi-Fi, use your computer's LAN IP, NOT localhost.
# Example: http://192.168.1.42:3000
BASE_URL=http://192.168.1.42:3000

NODE_ENV=development
