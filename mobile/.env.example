# Copy this file to .env and set it to your computer's LAN IP so a physical
# phone on the same Wi-Fi network can reach the backend API.
# Do NOT use localhost/127.0.0.1 here — on a physical device that points at
# the phone itself, not your development machine.
#
# Find your LAN IP with `ipconfig getifaddr en0` (Mac) or `ipconfig` (Windows).
EXPO_PUBLIC_API_URL=http://192.168.1.42:3000/api/v1
